  * {
    box-sizing: border-box;
  }

  html {
    font-size: 62.5%;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
  }

  body,
  h1,
  h2,
  h3,
  h4,
  h5,
  h5,
  h6,
  p,
  div {
    margin: 0;
    padding: 0;
  }

  /* regular font */
  @font-face {
    font-family: ${Ot.regular.name};
    src: url(${Ot.regular.file});
    font-weight: 600;
  }

  /* bold font */
  @font-face {
    font-family: ${Ot.bold.name};
    src: url(${Ot.bold.file});
    font-weight: 900;
  }

  /* secondary font */
  @font-face {
    font-family: ${Ot.secondary.name};
    src: url(${Ot.secondary.file});
    font-weight: 600;
  }
